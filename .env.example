NODE_ENV=development
PORT=8080

# SQLite Configuration
DB_PATH=data/dimpho_catering.sqlite

# Permanent production database
# Set this in Netlify to a hosted Postgres connection string.
# Example providers: Supabase, Neon, Railway, Render Postgres.
# Leave blank locally to use SQLite.
DATABASE_URL=
DATABASE_SSL=true

# Free WhatsApp click-to-chat configuration
# This creates pre-filled WhatsApp links. Customers still tap Send in WhatsApp.
ADMIN_WHATSAPP_NUMBER=+27796929591
WHATSAPP_NUMBER=27796929591

# Email Configuration
# For Gmail: Use App Password (not regular password)
# Generate here: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@dimphokelesego.com
ADMIN_EMAIL=dimphokelesego@gmail.com

# Other Email Providers:
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASSWORD=your-api-key
# Mailgun: SMTP_HOST=smtp.mailgun.org
# AWS SES: SMTP_HOST=email-smtp.region.amazonaws.com
